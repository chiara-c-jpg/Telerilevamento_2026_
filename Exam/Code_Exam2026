# Grafico comparativo finale (Borneo - Sumatra)
# Per confrontare le dinamiche territoriali tra le due isole, si realizza un grafico a barre raggruppate per anno, suddividendo le classi di copertura tramite "ggplot2" e "facet_wrap":

# Creazione del dataframe unico per i grafici  finali
tabella_totale <- data.frame(
  Regione = rep(c("Borneo", "Borneo", "Sumatra", "Sumatra"), each = 3),
  Anno = c(rep("2015", 3), rep("2025", 3), rep("2016", 3), rep("2025", 3)),
  Classe = rep(c("Suolo Nudo", "Piantagioni", "Foresta Primaria"), times = 4),
  Percentuale = c(perc_2015, perc_2025, perc_sum2016, perc_sum2025),
  Gruppo = c(rep("Borneo 2016", 3), rep("Borneo 2025", 3), rep("Sumatra 2016", 3), rep("Sumatra 2025", 3))
)

# Assicuriamoci che la colonna Classe mantenga l'ordine corretto
tabella_totale$Classe <- factor(tabella_totale$Classe, 
                                levels = c("Suolo Nudo", "Piantagioni", "Foresta Primaria"))  
# Utilizziamo la tabella_totale già creata in precedenza, impostando correttamente classe, anno e Regione siano impostati correttamente.
ggplot(tabella_totale, aes(x = Anno, y = Percentuale, fill = Classe)) +

# Barre raggruppate per classe all'interno di ciascun anno
geom_bar(stat = "identity", position = position_dodge(width = 0.8), width = 0.7) +
  
# Impostazione dei colori  per le classi di copertura
  scale_fill_manual(values = c(
    "Suolo Nudo" = "firebrick3", 
    "Piantagioni" = "goldenrod3", 
    "Foresta Primaria" = "forestgreen"
  )) +
  
  ylim(0, 100) +
  labs(title = "Dinamiche di Copertura (2016 vs 2025): Sumatra e Borneo", 
       y = "Percentuale (%)", 
       x = "Anno",
       fill = "Classe di Copertura") +
  
  theme_bw() +
  theme(axis.text.x = element_text(size = 12, face = "bold"),
        plot.title = element_text(hjust = 0.5, face = "bold", size = 14),
        strip.text = element_text(size = 13, face = "bold", color = "black"),
        strip.background = element_rect(fill = "gray90")) +
        
# Si divide il grafico in due scompartimenti: uno per il Borneo, uno per Sumatra
facet_wrap(~ Regione)

# grafico finale che confronta le tre classi per Sumatra e per il Borneo per entrambi gli anni.
# Preparazione del pannello e indicazione quali dati usare e su quali assi metterli.
# Il grafico si focalizza sulle singole classi individuate con tonalità di blu e viola.

ggplot(tabella_totale, aes(x = Anno, y = Percentuale, fill = Gruppo)) +
  geom_bar(stat = "identity", position = position_dodge(width = 0.85), width = 0.75) +
  scale_fill_manual(values = c(
    "Borneo 2016" = "#87CEFA",
    "Sumatra 2016" = "#DDA0DD",
    "Borneo 2025" = "#0000CD",
    "Sumatra 2025" = "#800080"
  )) +
  ylim(0, 100) +
  labs(title = "Confronto Borneo Sumatra", 
       y = "Percentuale (%)", 
       x = "Anno", 
       fill = "Isola e Anno") +
  theme_bw() +
  theme(
    axis.text.x = element_text(size = 11, face = "bold", color = "black"),
    axis.text.y = element_text(size = 10),
    axis.title.y = element_text(size = 12, face = "bold"),
    plot.title = element_text(hjust = 0.5, face = "bold", size = 13),
    strip.text = element_text(size = 12, face = "bold", color = "black"),
    strip.background = element_rect(fill = "gray90", color = "black", linewidth = 0.5),
    legend.title = element_text(size = 11, face = "bold"),
    legend.text = element_text(size = 10),
    panel.spacing = unit(1, "lines")
  ) +
  facet_wrap(~ Classe, labeller = as_labeller(c(
    "Suolo Nudo" = "Suolo Nudo",
    "Piantagioni" = "Piantagioni",
    "Foresta Primaria" = "Foresta"
  )))
