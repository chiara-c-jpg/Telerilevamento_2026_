# Calcolo DVI, NDVI e NDMI per l'area del Borneo

# Analisi DVI (Difference Vegetation Index)

# Calcolo DVI
dvi2015 <- borneo2015[["B8"]] - borneo2015[["B4"]]
dvi2025 <- borneo2025[["B8"]] - borneo2025[["B4"]]

# Imposta il layout affiancato: 1 riga, 2 colonne
par(mfrow=c(1, 2))

# Genera i due grafici
plot(dvi2015, main="DVI Borneo (2015)")
plot(dvi2025, main="DVI Borneo (2025)")

# Calcolo della differenza DVI 2015-2025
dvi_diff <- dvi2025 - dvi2015

# Impostazione del layout 
par(mfrow=c(1,1))

# Plot Differenza DVI 
plot(dvi_diff, col = cl_diff, main = "Differenza DVI (2025 - 2015)")

# Analisi NDVI  (Normalized Difference Vegetation Index) per il Borneo (2015 - 2025)

# Calcolo NDVI 2015 e 2025 tramite le bande 8=NIR, 4=Rosso
ndvi2015 <- (borneo2015[["B8"]] - borneo2015[["B4"]]) / (borneo2015[["B8"]] + borneo2015[["B4"]])
ndvi2025 <- (borneo2025[["B8"]] - borneo2025[["B4"]]) / (borneo2025[["B8"]] + borneo2025[["B4"]])

# Impostazione del layout
par(mfrow=c(1,2))

# Generazione dei grafici NDVI 2015 2025 affiancati tramite palette "viridis"
plot(ndvi2015, col=viridis(100), main="NDVI 2015")
plot(ndvi2025, col=viridis(100), main="NDVI 2025")

# Calcolo della differenza NDVI 2015-2025
ndvi_diff <- ndvi2025 - ndvi2015

# Impostazione schermo unico
par(mfrow=c(1,1))

# Plot Differenza NDVI
plot(ndvi_diff, col = cl_diff, main = "Differenza NDVI (2025 - 2015)")

### Analisi NDMI (Normalized Difference Mustoire Index)

## Calcolo NDMI 2015 2025

# Calcolo NDMI tramite le bande 8=NIR e 11=SWIR
ndmi2015 <- (borneo2015[["B8"]] - borneo2015[["B11"]]) / (borneo2015[["B8"]] + borneo2015[["B11"]])
ndmi2025 <- (borneo2025[["B8"]] - borneo2025[["B11"]]) / (borneo2025[["B8"]] + borneo2025[["B11"]])

# Impostazione del layout affiancato
par(mfrow=c(1,2))

# Generazione dei grafici NDMI 2015 e 2025 affiancati
plot(ndmi2015, col=viridis(100), main="NDMI 2015")
plot(ndmi2025, col=viridis(100), main="NDMI 2025")


# Differenza NDMI (2025 - 2015)
# Calcoliamo la differenza dell'NDMI per evidenziare le variazioni nel contenuto d'acqua della vegetazione nel decennio 2015 2025

# Calcolo della differenza NDMI
ndmi_diff <- ndmi2025 - ndmi2015

# reset pannel grafico
par(mfrow=c(1,1))

# Plot della diffrenza NDMI 
plot(ndmi_diff, col=cl_diff, main="Differenza NDMI (2025 - 2015))

# Definizione dei colori per le 3 classi
colori_classi <- c("red", "yellow", "darkgreen")

# Matrice di classificazione basata sull'NDVI
matrice_class <- matrix(c(
  -Inf, 0.4, 1, # Classe 1: Suolo nudo/Deforestazione
   0.4, 0.7, 2, # Classe 2: Piantagioni
   0.7, Inf, 3  # Classe 3: Foresta primaria intatta
), ncol = 3, byrow = TRUE)

# Classificazione tramite la funzione classify()
ndvi2015_class <- classify(ndvi2015, matrice_class)
ndvi2025_class <- classify(ndvi2025, matrice_class)

# Imposta il layout
layout(matrix(c(1, 2, 3), nrow=1), widths=c(1, 1, 0.3))

# Riduci i margini attorno alle mappe per ingrandirle (sotto, sinistra, sopra, destra)
par(mar=c(2.5, 2.5, 3, 1)) 

# Plot delle due mappe con i colori assegnati
plot(ndvi2015_class, col=colori_classi, main="Classificazione 2015", legend=FALSE)
plot(ndvi2025_class, col=colori_classi, main="Classificazione 2025", legend=FALSE)

# Azzera i margini per il pannello della legenda e inseriscila
par(mar=c(0, 0, 0, 0)) 
plot.new()
legend("center", 
       legend=c("1", "2", "3"), 
       fill=colori_classi, 
       xpd=TRUE,       
       bty="n",        
       cex=1.5)

